# See https://help.github.com/articles/ignoring-files for more about ignoring files.

/.bundle
/vendor/*
!/vendor/.keep

/.env*
/config/master.key
/config/credentials.yml.enc
.kamal/secrets

/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

/tmp/pids/*
/tmp/storage/*
!/tmp/pids/.keep
!/tmp/storage/.keep

/storage/*
!/storage/.keep

.dockerignore
Dockerfile
.kamal/
bin/docker-entrypoint
bin/kamal

.DS_Store
*.swp
.vscode/

node_modules/
yarn-error.log

.byebug_history
.env
